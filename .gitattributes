# LF/CRLF cross-platform uyumluluk (WSL + Windows)
* text=auto

# SystemVerilog ve C dosyaları kesinlikle LF
*.sv  text eol=lf
*.svh text eol=lf
*.v   text eol=lf
*.vh  text eol=lf
*.c   text eol=lf
*.h   text eol=lf
*.py  text eol=lf
*.sh  text eol=lf
*.tcl text eol=lf

# İkili dosyalar
*.mem binary
*.bin binary
*.bit binary
